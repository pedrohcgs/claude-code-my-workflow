# ==============================================================================
# .gitignore for RetPartner (Python + Stata Data Linkage Project)
# ==============================================================================

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# Jupyter
.ipynb_checkpoints/

# Stata
*.smcl
*.gph

# Data files (too large for git — use data versioning or shared storage)
data/raw/**
data/processed/**
data/output/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/output/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Virtual environments
.venv/
venv/
env/

# Output artifacts (regenerated by scripts)
# Uncomment if you want to track figures/tables in git:
# output/figures/
# output/tables/
