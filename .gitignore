# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo
**/__pycache__/
**/*.py[cod]

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db
**/.DS_Store

# Claude/Codex machine-local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md
.claude/skills/local/

# Local AI tooling directories
.codebuddy/
.commandcode/
.continue/
.crush/
.factory/
.goose/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.minimax/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/
.zencoder/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Local environments and package installs
**/.venv*/
**/node_modules/

# Local scratch and intake area
.tmp_pptx/
workspace-local/*
!workspace-local/
!workspace-local/README.md

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
