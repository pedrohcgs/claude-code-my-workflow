# ==============================================================================
# .gitignore for China Innovation Tax Benefits Study
# ==============================================================================

# ==============================================================================
# Data — proprietary CSMAR/CNRDS data cannot be committed
# ==============================================================================
data/raw/
!data/raw/.gitkeep

# Large raw Stata datasets
data/raw/*.dta

# Literature PDFs (large files — store locally or in cloud)
literature/
!literature/.gitkeep

# ==============================================================================
# Stata
# ==============================================================================
# Log files (optional — uncomment to gitignore logs)
# output/logs/
# *.log

# Stata temporary files
*.stswp
~*.dta

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.env

# ==============================================================================
# OS files
# ==============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ==============================================================================
# Claude Code local files (not shared across machines)
# ==============================================================================
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# ==============================================================================
# IDE
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# Office temporary files
# ==============================================================================
~$*.docx
~$*.xlsx
~$*.pptx
